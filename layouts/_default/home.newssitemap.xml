{{- /*
  news-sitemap — Google News sitemap.
  Lists ONLY articles published in the last 48 hours (Google News rule).
  Rebuilds on every deploy, so the 48-hour window stays current automatically.
  Required news tags: publication (name + language), publication_date, title.
*/ -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:news="http://www.google.com/schemas/sitemap-news/0.9">
{{- $cutoff := now.AddDate 0 0 -2 }}
{{- range .Site.Pages }}
  {{- if and (eq .Kind "page") (eq .Type "posts") (ge .Date $cutoff) (not .Draft) }}
  <url>
    <loc>{{ .Permalink }}</loc>
    <news:news>
      <news:publication>
        <news:name>{{ .Site.Title }}</news:name>
        <news:language>{{ .Site.Language.Lang }}</news:language>
      </news:publication>
      <news:publication_date>{{ .Date.Format "2006-01-02T15:04:05Z07:00" }}</news:publication_date>
      <news:title>{{ .Title | plainify }}</news:title>
    </news:news>
    <lastmod>{{ .Lastmod.Format "2006-01-02T15:04:05Z07:00" }}</lastmod>
  </url>
  {{- end }}
{{- end }}
</urlset>
